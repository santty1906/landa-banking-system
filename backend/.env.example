APP_ENV=development
APP_NAME=Landa Backend API
APP_VERSION=0.1.0
API_V1_PREFIX=/api/v1

POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=landa_db
POSTGRES_USER=landa_user
